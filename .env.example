# Resend — contact form (https://resend.com). Required for /api/contact in production.
RESEND_API_KEY=re_xxxxxxxx

# Inbound address for contact form notifications (your verified inbox).
CONTACT_TO_EMAIL=sm@smatdesigns.com

# Sender — use a domain you verify in Resend (e.g. onboarding@resend.dev only for quick tests).
CONTACT_FROM_EMAIL="SMAT Designs <onboarding@resend.dev>"
